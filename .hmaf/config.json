{
  "project": "hmaf",
  "version": "0.1.0",
  "modules": {
    "voice": true,
    "teams": true,
    "router": true
  },
  "sessionPrompt": true,
  "routing": {
    "architecture": "claude-sonnet",
    "research":     "claude-sonnet",
    "planning":     "claude-sonnet",
    "review":       "claude-sonnet",
    "ios-code":     "gemini-flash",
    "backend-code": "gemini-flash",
    "web-code":     "gemini-flash",
    "devops":       "gemini-flash",
    "simple-fix":   "gemini-flash",
    "unknown":      "claude-sonnet"
  },
  "providers": {
    "claude-sonnet": {
      "model":   "claude-sonnet-4-6",
      "envKey":  "ANTHROPIC_API_KEY",
      "costPer1MInput":  3.0,
      "costPer1MOutput": 15.0
    },
    "gemini-flash": {
      "model":   "models/gemini-2.5-flash",
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
      "envKey":  "GEMINI_API_KEY",
      "costPer1MInput":  0.075,
      "costPer1MOutput": 0.30
    }
  },
  "teams": {
    "executor": "claude-task",
    "debateRounds": 2,
    "pauseBetweenRounds": true,
    "outputDir": "docs/03-session-state/team-debates"
  },
  "gate": {
    "mode": "smart"
  },
  "voice": {
    "sttProvider": "soniox",
    "ttsProvider": "macos",
    "language": "vi"
  }
}
