# Anthropic (Claude) — required for Reasoning & Architecture tasks
ANTHROPIC_API_KEY=sk-ant-...

# Soniox — required for Voice-First Workflow (Module 1)
SONIOX_API_KEY=...

# OpenAI — optional, for TTS output (falls back to macOS `say`)
OPENAI_API_KEY=sk-...

# Gemini — for iOS/Web/Backend code tasks (40x cheaper than Claude, free tier available)
# Get key: aistudio.google.com → Get API key
GEMINI_API_KEY=...

# HMAF Settings
HMAF_LOG_LEVEL=info
HMAF_GATE_MODE=smart         # smart | strict | auto
HMAF_VOICE_LANG=vi-VN        # Vietnamese-first
HMAF_TTS_PROVIDER=macos      # macos | openai | elevenlabs
