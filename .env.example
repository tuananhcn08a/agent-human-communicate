# HMAF Environment Variables

# Gemini — dùng cho code tasks (ios, backend, web, simple-fix)
# Lấy tại: aistudio.google.com → Get API key (miễn phí)
GEMINI_API_KEY=...

# Soniox — chỉ cần nếu dùng Voice module
# Lấy tại: soniox.com/dashboard
SONIOX_API_KEY=...

# OpenAI — chỉ cần nếu muốn dùng OpenAI TTS thay macOS say
# OPENAI_API_KEY=sk-...

# HMAF settings
HMAF_LOG_LEVEL=info        # silent | info
HMAF_GATE_MODE=smart       # smart | strict | auto
HMAF_TTS_PROVIDER=macos    # macos | openai
