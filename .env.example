# Anthropic (Claude) — required for Reasoning & Architecture tasks
ANTHROPIC_API_KEY=sk-ant-...

# Soniox — required for Voice-First Workflow (Module 1)
SONIOX_API_KEY=...

# OpenAI — optional, for TTS output (falls back to macOS `say`)
OPENAI_API_KEY=sk-...

# DeepSeek — for iOS/Android code tasks (cost-optimized)
DEEPSEEK_API_KEY=...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen (Alibaba) — for Web/Backend code tasks (cost-optimized)
QWEN_API_KEY=...
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# HMAF Settings
HMAF_LOG_LEVEL=info
HMAF_GATE_MODE=smart         # smart | strict | auto
HMAF_VOICE_LANG=vi-VN        # Vietnamese-first
HMAF_TTS_PROVIDER=macos      # macos | openai | elevenlabs
